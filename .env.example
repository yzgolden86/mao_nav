# 环境变量配置示例文件
# 复制此文件为 .env 并填入实际的值

# ============================================
# 前端配置（VITE_ 前缀，构建时注入，非敏感）
# ============================================

VITE_GITHUB_OWNER=your_github_username
VITE_GITHUB_REPO=mao_nav
VITE_GITHUB_BRANCH=master

# 启用访问锁定（设置任意值启用，留空或删除则不启用）
# VITE_OPEN_LOCK=true

# ============================================
# 服务端密钥（不加 VITE_ 前缀，前端不可见）
# ============================================
# 本地开发：写入 .dev.vars 文件
# CF Pages / Vercel：写入平台的环境变量设置
#
# ADMIN_PASSWORD=your_admin_password_here
# GITHUB_TOKEN=your_github_token_here

# ============================================
# 使用说明
# ============================================

# 1. 如果你不需要管理员界面，可以忽略密钥配置
# 2. 如果需要管理员界面，请：
#    - 在 GitHub 创建 Fine-grained Personal Access Token
#    - 仓库只选择 mao_nav，防止 token 泄露影响其他工程
#    - 设置 Contents: Read and write 权限
#    - 设置 Metadata: Read 权限
# 3. 密钥类变量通过服务端 Functions 使用，不会暴露在前端代码中
# 4. 同时支持 Cloudflare Pages 和 Vercel 部署
